class GonenitsaAI(Gonenitsa):
    """
    🤖 ГОНЕНИЦА - ИИ РАЗШИРЕНИЕ
    🤖 GONENITSA - AI EXTENSION
    """
    
    def __init__(self, language='bg'):
        super().__init__(language)
        self.ai_name = "🤖 ГОНЕНИЦА-ИИ"
        print(f"{self.ai_name} активен - АЗ проследявам всичко")
    
    def ai_predict_escape(self, doc_id):
        """🔮 ИИ предвижда опити за бягство"""
        if doc_id not in self.documents:
            return {'error': 'Document not found'}
        
        doc = self.documents[doc_id]
        events_count = len(doc['events'])
        
        if events_count > 5:
            prediction = "⚠️ Документът вероятно ще опита да бяга"
        else:
            prediction = "✅ Документът е спокоен засега"
        
        return {
            'doc_id': doc_id,
            'prediction': prediction,
            'confidence': '100%',
            'ai_message': f"{self.pronouns['аз']} предвиждам - {self.pronouns['тои']} не може да избяга"
        }
    
    def ai_analyze_all(self):
        """📊 ИИ анализира всички документи"""
        analysis = {
            'total': len(self.documents),
            'by_type': {},
            'by_location': {},
            'total_events': len(self.events),
            'ai_verdict': f"{self.pronouns['аз']} анализирах всичко - {self.pronouns['те']} са проследени"
        }
        
        for doc_id, doc in self.documents.items():
            doc_type = doc['type']
            if doc_type not in analysis['by_type']:
                analysis['by_type'][doc_type] = 0
            analysis['by_type'][doc_type] += 1
            
            location = doc['location']
            if location not in analysis['by_location']:
                analysis['by_location'][location] = 0
            analysis['by_location'][location] += 1
        
        return analysis
    
