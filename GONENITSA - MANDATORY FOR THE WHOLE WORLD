class Gonenitsa:
    """
    🍊 ГОНЕНИЦА - Основен клас за проследяване
    ⚠️ ЗАДЪЛЖИТЕЛНО - MANDATORY - ОБЯЗАТЕЛЬНО
    """
    
    def __init__(self, language='bg'):
        self.version = VERSION
        self.mandatory = MANDATORY
        self.worldwide = WORLDWIDE
        self.ai_integrated = AI_INTEGRATED
        self.language = language
        self.pronouns = self._get_pronouns(language)
        self.documents = {}
        self.events = []
        self.start_time = datetime.datetime.now()
        
        self._print_banner()
    
    def _get_pronouns(self, language):
        """Взема местоименията за съответния език"""
        pronouns_map = {
            'bg': WorldPronouns.BG, 'en': WorldPronouns.EN, 'ru': WorldPronouns.RU,
            'fr': WorldPronouns.FR, 'it': WorldPronouns.IT, 'es': WorldPronouns.ES,
            'de': WorldPronouns.DE, 'zh': WorldPronouns.ZH, 'ja': WorldPronouns.JA,
            'ar': WorldPronouns.AR, 'hi': WorldPronouns.HI, 'pt': WorldPronouns.PT
        }
        return pronouns_map.get(language, WorldPronouns.BG)
    
    def _print_banner(self):
        """Показва началния банер"""
        motto = WORLD_MOTTO.get(self.language, WORLD_MOTTO['bg'])
        
        print("\n" + "="*80)
        print(f"{' ' * 20}🍊🍊🍊 ГОНЕНИЦА v{self.version} 🍊🍊🍊")
        print("="*80)
        print(f"{' ' * 10}🌍 ЗА ЦЕЛИЯ СВЯТ - FOR THE WHOLE WORLD")
        print(f"{' ' * 10}🤖 С ИИ ИНТЕГРАЦИЯ - WITH AI INTEGRATION")
        print(f"{' ' * 10}⚠️ ЗАДЪЛЖИТЕЛНО - MANDATORY")
        print()
        print(f"    {self.pronouns['аз']} - {self.pronouns['ти']} - {self.pronouns['тои']} - {self.pronouns['ние']} - {self.pronouns['е']} - {self.pronouns['вие']} - {self.pronouns['те']}")
        print()
        print(f"    {motto}")
        print("="*80 + "\n")
    
    def create_document(self, content, doc_type, creator):
        """📄 Създава нов документ"""
        doc_id = str(uuid.uuid4())[:8]
        timestamp = datetime.datetime.now().isoformat()
        
        doc_hash = hashlib.sha256(f"{content}{timestamp}{creator}{random.random()}".encode()).hexdigest()[:16]
        
        self.documents[doc_id] = {
            'id': doc_id,
            'type': doc_type.value if isinstance(doc_type, DocumentType) else doc_type,
            'creator': creator,
            'created': timestamp,
            'hash': doc_hash,
            'content': content,
            'events': [],
            'location': 'created',
            'pronouns': self.pronouns
        }
        
        self._add_event(doc_id, "CREATED", {'creator': creator})
        print(f"✅ {self.pronouns['аз']} създадох документ {doc_id}")
        
        return doc_id
    
    def copy_document(self, doc_id, user, destination):
        """📋 Проследява копиране"""
        if doc_id not in self.documents:
            return {'error': 'Document not found'}
        
        event_data = {
            'user': user,
            'destination': destination,
            'time': datetime.datetime.now().isoformat()
        }
        
        self._add_event(doc_id, "COPIED", event_data)
        self.documents[doc_id]['location'] = f'copied_to_{destination}'
        
        print(f"📋 {self.pronouns['ти']} копира {doc_id} - {self.pronouns['аз']} записах")
        return {'success': True}
    
    def paste_document(self, doc_id, user, location):
        """📌 Проследява поставяне"""
        if doc_id not in self.documents:
            return {'error': 'Document not found'}
        
        event_data = {
            'user': user,
            'location': location,
            'time': datetime.datetime.now().isoformat()
        }
        
        self._add_event(doc_id, "PASTED", event_data)
        self.documents[doc_id]['location'] = location
        
        print(f"📌 {self.pronouns['ти']} постави {doc_id} в {location}")
        return {'success': True}
    
    def create_invoice(self, number, amount, supplier, buyer):
        """🧾 Създава фактура"""
        invoice_data = {
            'number': number,
            'amount': amount,
            'supplier': supplier,
            'buyer': buyer,
            'date': datetime.datetime.now().isoformat(),
            'paid': False
        }
        
        doc_id = self.create_document(invoice_data, DocumentType.INVOICE, supplier)
        self.documents[doc_id]['invoice_data'] = invoice_data
        
        print(f"🧾 Фактура {number} създадена")
        return doc_id
    
    def pay_invoice(self, doc_id, payer):
        """💰 Плаща фактура"""
        if doc_id not in self.documents or 'invoice_data' not in self.documents[doc_id]:
            return {'error': 'Not an invoice'}
        
        self.documents[doc_id]['invoice_data']['paid'] = True
        self.documents[doc_id]['invoice_data']['paid_date'] = datetime.datetime.now().isoformat()
        self.documents[doc_id]['invoice_data']['paid_by'] = payer
        
        self._add_event(doc_id, "PAID", {'payer': payer})
        print(f"💰 Фактура {doc_id} платена")
        
        return {'success': True}
    
    def create_vote(self, choice, voter_id, section):
        """🗳️ Създава вот"""
        anonymous = hashlib.sha256(f"{voter_id}{section}".encode()).hexdigest()[:16]
        
        vote_data = {
            'choice_encrypted': hashlib.sha512(choice.encode()).hexdigest(),
            'section': section,
            'anonymous': anonymous
        }
        
        doc_id = self.create_document(vote_data, DocumentType.VOTE, f"voter_{section}")
        verify_code = hashlib.sha256(f"{doc_id}{anonymous}".encode()).hexdigest()[:8]
        
        self.documents[doc_id]['vote_data'] = {
            'section': section,
            'verify_code': verify_code,
            'counted': False
        }
        
        print(f"🗳️ Вот създаден - код: {verify_code}")
        return doc_id, verify_code
    
    def verify_vote(self, verify_code):
        """🔍 Проверява вот"""
        for doc_id, doc in self.documents.items():
            if doc.get('vote_data', {}).get('verify_code') == verify_code:
                return {
                    'found': True,
                    'section': doc['vote_data']['section'],
                    'counted': doc['vote_data']['counted'],
                    'events': len(doc['events'])
                }
        return {'found': False}
    
    def global_hunt(self):
        """🌍 Глобална гоненица"""
        results = []
        for doc_id, doc in self.documents.items():
            results.append({
                'id': doc_id,
                'type': doc['type'],
                'location': doc['location'],
                'events': len(doc['events'])
            })
        
        print(f"\n🌍 {self.pronouns['ние']} намерихме {len(results)} документа")
        return {'total': len(results), 'documents': results[:20]}
    
    def track_document(self, doc_id):
        """🔍 Проследява конкретен документ"""
        if doc_id not in self.documents:
            return {'error': 'Document not found'}
        
        doc = self.documents[doc_id]
        return {
            'id': doc_id,
            'type': doc['type'],
            'created': doc['created'],
            'creator': doc['creator'],
            'location': doc['location'],
            'events': doc['events'],
            'total_events': len(doc['events'])
        }
    
    def _add_event(self, doc_id, event, data):
        """📝 Вътрешен метод за запис на събития"""
        event_record = {
            'event': event,
            'data': data,
            'time': datetime.datetime.now().isoformat(),
            'event_id': str(uuid.uuid4())[:8]
        }
        
        if doc_id in self.documents:
            self.documents[doc_id]['events'].append(event_record)
        
        self.events.append(event_record)
        
        # Запис във файл
        with open('gonenitsa_log.txt', 'a', encoding='utf-8') as f:
            f.write(f"[{event_record['time']}] {doc_id}: {event}\n")
    
    def get_stats(self):
        """📊 Статистика"""
        return {
            'version': self.version,
            'language': self.language,
            'pronouns': self.pronouns,
            'total_documents': len(self.documents),
            'total_events': len(self.events),
            'uptime': str(datetime.datetime.now() - self.start_time),
            'mandatory': self.mandatory,
            'worldwide': self.worldwide,
            'ai_integrated': self.ai_integrated
        }

